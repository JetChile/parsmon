# ParsMon — переменные окружения. На DO задаются в UI (BOT_TOKEN — Encrypted).
# Локально: cp .env.example .env  и заполнить.

# ОБЯЗАТЕЛЬНО — токен @parsmonbot из @BotFather
BOT_TOKEN=

# Группа с закреплёнными сообщениями («Чек #N» и список самокатов)
SOURCE_CHAT_ID=-1002300878026

# Чат, куда слать алерты операторам (испанский)
ALERT_CHAT_ID=-1003727768555

# Режим чтения: getupdates (по умолчанию) | forward | getchat
#  getupdates — бот сам слушает группу (нужен privacy OFF или admin)
#  forward    — читает 2 сообщения по id (не конфликтует с другими потребителями токена)
READ_MODE=getupdates

# Только для READ_MODE=forward:
CHEK_MSG_ID=
SCOOTER_MSG_ID=
LOG_CHAT_ID=

# Период опроса, секунды
LOOP_SECONDS=120

# Файл состояния (на DO-воркере эфемерный)
STATE_FILE=state.json
